{
  "title": "Rapid — Game Server",
  "uid": "rapid-server",
  "tags": ["rapid", "game", "backend"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "title": "Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Active Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "rapid_ws_connections_active", "legendFormat": "connections" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 }] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "Active Games",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "rapid_games_active", "legendFormat": "games" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "Games Played (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "increase(rapid_games_total[24h])", "legendFormat": "games" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "blue", "value": null }] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "Rounds Played (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "increase(rapid_rounds_total[24h])", "legendFormat": "rounds" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "blue", "value": null }] } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "Latency",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "title": "RTT Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "rapid_rtt_ms_bucket", "legendFormat": "{{le}}", "format": "heatmap" }],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "options": { "bucketSize": 10, "combine": true, "fillOpacity": 80 }
    },
    {
      "title": "Fair Time Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "rapid_fair_time_ms_bucket", "legendFormat": "{{le}}", "format": "heatmap" }],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "options": { "bucketSize": 100, "combine": true, "fillOpacity": 80 }
    },
    {
      "title": "Raw vs Fair Time (P50)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "histogram_quantile(0.5, rate(rapid_answer_latency_raw_ms_bucket[5m]))", "legendFormat": "Raw P50" },
        { "expr": "histogram_quantile(0.5, rate(rapid_fair_time_ms_bucket[5m]))", "legendFormat": "Fair P50" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "title": "P95 Answer Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "histogram_quantile(0.95, rate(rapid_fair_time_ms_bucket[5m]))", "legendFormat": "P95 Fair Time" }],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "title": "Game Metrics",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "title": "Games per Category",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "rapid_games_total", "legendFormat": "{{category}}" }],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "orientation": "horizontal", "showValue": "always" }
    },
    {
      "title": "Correct Answer Rate by Category",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "sum(rate(rapid_rounds_total{correct=\"true\"}[1h])) by (category) / sum(rate(rapid_rounds_total[1h])) by (category)", "legendFormat": "{{category}}" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "options": { "orientation": "horizontal", "showValue": "always" }
    },
    {
      "title": "Timeout Rate by Category",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "rate(rapid_timeout_rounds_total[1h])", "legendFormat": "{{category}}" }],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "options": { "orientation": "horizontal", "showValue": "always" }
    },
    {
      "title": "Score Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "rapid_score_distribution_bucket", "legendFormat": "{{le}}", "format": "heatmap" }],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "options": { "bucketSize": 50, "combine": true, "fillOpacity": 80 }
    },
    {
      "title": "Infrastructure",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false
    },
    {
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "sum(rate(http_server_request_duration_seconds_count[5m])) by (http_route)", "legendFormat": "{{http_route}}" }],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 20, "stacking": { "mode": "normal" } } }, "overrides": [] }
    },
    {
      "title": "DB Query Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "histogram_quantile(0.5, rate(db_client_operation_duration_seconds_bucket[5m]))", "legendFormat": "P50" },
        { "expr": "histogram_quantile(0.95, rate(db_client_operation_duration_seconds_bucket[5m]))", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.99, rate(db_client_operation_duration_seconds_bucket[5m]))", "legendFormat": "P99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "title": "DB Connection Pool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "db_client_operation_duration_seconds_count", "legendFormat": "queries total" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "title": "Go Runtime",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "go_goroutines", "legendFormat": "goroutines" },
        { "expr": "go_memstats_alloc_bytes / 1024 / 1024", "legendFormat": "heap MB" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 } }, "overrides": [] }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" },
        "hide": 2
      }
    ]
  }
}
